---
import { site, navKeys } from '../data/site';
import { routes, t, hours, type Lang } from '../data/content';
interface Props { lang: Lang; page: string; title: string; description: string; }
const { lang, page, title, description } = Astro.props;
const L = t[lang];
const r = routes[lang];
const base = import.meta.env.BASE_URL;
const other = L.other;
// URLs absolutas para SEO / vista previa al compartir
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(base + 'assets/hero-carrusel2.jpg', Astro.site).href;
// Datos estructurados de negocio local (una vez por página)
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Physiotherapy',
  name: 'Fisioymés',
  image: ogImage,
  url: new URL(base, Astro.site).href,
  telephone: '+34664762570',
  email: site.email,
  priceRange: '€€',
  address: { '@type': 'PostalAddress', streetAddress: 'Carrer Xerric 4, Local 1', addressLocality: 'Sant Cugat del Vallès', addressRegion: 'Barcelona', postalCode: '08172', addressCountry: 'ES' },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday'], opens: '09:00', closes: '21:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Friday', opens: '09:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Saturday', opens: '10:00', closes: '14:00' },
  ],
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '5.0', reviewCount: '66' },
  sameAs: [site.facebook, site.instagram],
});
// Logos de redes en SVG (currentColor → heredan el color del contenedor).
const fbIcon = '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.55-1.5h1.65V3.6c-.3 0-1.3-.1-2.5-.1-2.5 0-4.25 1.55-4.25 4.35v2.05H7.3V13h2.65v8h3.55z"/></svg>';
const igIcon = '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2.2c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.42.56.22.96.48 1.38.9.42.42.68.82.9 1.38.17.42.37 1.06.42 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.42 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.17-1.06.37-2.23.42-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.42-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.17-.42-.37-1.06-.42-2.23C2.21 15.58 2.2 15.2 2.2 12s.01-3.58.07-4.85c.05-1.17.25-1.8.42-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.17 1.06-.37 2.23-.42C8.42 2.21 8.8 2.2 12 2.2zm0 1.8c-3.14 0-3.51.01-4.75.07-.9.04-1.38.19-1.71.32-.43.17-.74.37-1.06.69-.32.32-.52.63-.69 1.06-.13.33-.28.81-.32 1.71C3.21 8.49 3.2 8.86 3.2 12s.01 3.51.07 4.75c.04.9.19 1.38.32 1.71.17.43.37.74.69 1.06.32.32.63.52 1.06.69.33.13.81.28 1.71.32 1.24.06 1.61.07 4.75.07s3.51-.01 4.75-.07c.9-.04 1.38-.19 1.71-.32.43-.17.74-.37 1.06-.69.32-.32.52-.63.69-1.06.13-.33.28-.81.32-1.71.06-1.24.07-1.61.07-4.75s-.01-3.51-.07-4.75c-.04-.9-.19-1.38-.32-1.71-.17-.43-.37-.74-.69-1.06-.32-.32-.63-.52-1.06-.69-.33-.13-.81-.28-1.71-.32C15.51 4.01 15.14 4 12 4zm0 3.05A4.95 4.95 0 1 1 12 17a4.95 4.95 0 0 1 0-9.9zm0 1.8A3.15 3.15 0 1 0 12 15.15 3.15 3.15 0 0 0 12 8.85zm5.15-.9a1.15 1.15 0 1 1-2.3 0 1.15 1.15 0 0 1 2.3 0z"/></svg>';
// Ruta equivalente en el otro idioma para el conmutador.
const otherRoute = routes[other.code as Lang][page];
const waLink = `https://wa.me/${site.whatsapp}`;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Se ejecuta antes del primer pintado: marca los elementos como ocultos ANTES de que se vean (evita el parpadeo). Solo si hay JS y no hay reduced-motion. -->
  <script is:inline>
    try { if (!matchMedia('(prefers-reduced-motion: reduce)').matches) document.documentElement.classList.add('js-reveal'); } catch (e) {}
  </script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/png" href={base + 'assets/favicon.png'} />
  <link rel="apple-touch-icon" href={base + 'assets/favicon.png'} />
  <link rel="alternate" hreflang={lang} href={r[page]} />
  <link rel="alternate" hreflang={other.code} href={otherRoute} />
  <!-- Vista previa al compartir (Open Graph / Twitter) -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Fisioymés" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content={lang === 'ca' ? 'ca_ES' : 'es_ES'} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={jsonLd} is:inline />
</head>
<body>
  <!-- Barra superior: teléfono + redes -->
  <div class="topbar">
    <div class="wrap topbar-in">
      <a href={site.phoneHref} class="topbar-phone">☎ {site.phone}</a>
      <span class="topbar-addr">{site.address} · {site.city}</span>
      <span class="topbar-social">
        <a href={site.facebook} aria-label="Facebook" target="_blank" rel="noopener"><Fragment set:html={fbIcon} /></a>
        <a href={site.instagram} aria-label="Instagram" target="_blank" rel="noopener"><Fragment set:html={igIcon} /></a>
      </span>
    </div>
  </div>

  <!-- Cabecera -->
  <header class="header">
    <div class="wrap header-in">
      <a href={r.home} class="logo"><img src={base + 'assets/FISIOYMES-LOGO.png'} alt="Fisioymés" width="150" height="42" /></a>
      <input type="checkbox" id="navtoggle" class="navtoggle" />
      <label for="navtoggle" class="burger" aria-label="Menú"><span></span><span></span><span></span></label>
      <nav class="nav">
        {navKeys.filter(k => k !== 'booking').map(k => (
          <a href={r[k]} class={page === k ? 'active' : ''}>{L.nav[k]}</a>
        ))}
        <a href={r.booking} class="nav-cta">{L.nav.booking}</a>
        <span class="lang">
          <a href={otherRoute} aria-label={`Canvia a ${other.name}`}>{other.name}</a>
        </span>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Pie -->
  <footer class="footer">
    <div class="wrap footer-grid">
      <div>
        <img src={base + 'assets/logo-fisioymes-blanco.png'} alt="Fisioymés" width="150" height="33" class="footer-logo" />
        <p class="footer-tag">{L.footer.tagline}</p>
        <p><a href={site.mapsUrl} target="_blank" rel="noopener" class="footer-link">{site.address}<br />{site.city}</a></p>
        <p><a href={site.phoneHref} class="footer-link">{site.phone}</a><br /><a href={`mailto:${site.email}`} class="footer-link">{site.email}</a></p>
      </div>
      <div>
        <h3>{L.footer.hours}</h3>
        <ul class="hours-list">
          {L.days.map((day, i) => (
            <li><span>{day}</span><span>{hours[i] ?? '—'}</span></li>
          ))}
        </ul>
      </div>
      <div>
        <h3>{L.footer.follow}</h3>
        <div class="footer-social">
          <a href={site.facebook} aria-label="Facebook" target="_blank" rel="noopener"><Fragment set:html={fbIcon} /></a>
          <a href={site.instagram} aria-label="Instagram" target="_blank" rel="noopener"><Fragment set:html={igIcon} /></a>
        </div>
        <a href={r.booking} class="btn btn-light footer-book">{L.cta.book}</a>
      </div>
    </div>
    <div class="wrap footer-legal">© {new Date().getFullYear()} Fisioymés · {L.footer.rights}</div>
  </footer>

  <!-- WhatsApp flotante -->
  <a href={waLink} class="wa-fab" target="_blank" rel="noopener" aria-label={L.cta.whatsapp}>
    <svg viewBox="0 0 32 32" width="30" height="30" aria-hidden="true"><path fill="#fff" d="M16 3C9.4 3 4 8.4 4 15c0 2.1.6 4.2 1.6 6L4 29l8.2-1.6c1.7.9 3.7 1.4 5.8 1.4 6.6 0 12-5.4 12-12S22.6 3 16 3zm0 21.8c-1.8 0-3.6-.5-5.1-1.4l-.4-.2-3.7.7.7-3.6-.2-.4C6.5 18.9 6 17 6 15 6 9.5 10.5 5 16 5s10 4.5 10 10-4.5 9.8-10 9.8zm5.5-7.4c-.3-.2-1.8-.9-2-1-.3-.1-.5-.2-.7.2s-.8 1-.9 1.2c-.2.2-.3.2-.6.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5s-.7-1.7-1-2.3c-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.1-.3-.2-.6-.3z"/></svg>
  </a>

  <!-- El ocultado lo hace el CSS bajo .js-reveal (activado en <head>). Aquí solo escalonamos y disparamos el revelado al entrar en pantalla. -->
  <script is:inline>
    (function () {
      if (!document.documentElement.classList.contains('js-reveal')) return; // reduced-motion o sin JS previo
      var sel = '.section-head, .tx-card, .team-card, .price-card, .clinic-item, .clinic-text p, .rev, .lesion, .partner-logo';
      function start() {
        var els = document.querySelectorAll(sel);
        // escalonado en cascada: retardo según la posición dentro de cada grupo (mismo contenedor)
        var counts = new Map();
        for (var i = 0; i < els.length; i++) {
          var el = els[i], p = el.parentElement, n = counts.get(p) || 0;
          el.style.transitionDelay = Math.min(n * 90, 450) + 'ms';
          counts.set(p, n + 1);
        }
        if (!('IntersectionObserver' in window)) {
          for (var j = 0; j < els.length; j++) els[j].classList.add('in');
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
        }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });
        els.forEach(function (el) { io.observe(el); });
      }
      if (document.readyState !== 'loading') start();
      else document.addEventListener('DOMContentLoaded', start);
    })();
  </script>
</body>
</html>

<style is:global>
  :root {
    --blue: #2ea3f2;
    --blue-d: #1c7fc9;
    --blue-dd: #0f5c9e;
    --heading: #0c3357;
    --ink: #1f2a37;
    --muted: #5b6b7b;
    --bg: #ffffff;
    --bg-soft: #f4f8fc;
    --line: #e4ecf3;
    --wa: #25d366;
    --wrap: 1160px;
  }
  * { box-sizing: border-box; }
  /* El menú off-canvas se coloca fuera de pantalla a la derecha; clipamos el overflow-x para que no genere scroll horizontal. */
  html { scroll-behavior: smooth; overflow-x: hidden; }
  body { margin: 0; overflow-x: hidden; font-family: 'Open Sans', system-ui, sans-serif; color: var(--ink); background: var(--bg); line-height: 1.6; -webkit-font-smoothing: antialiased; }
  h1,h2,h3 { font-family: 'Montserrat', system-ui, sans-serif; line-height: 1.15; margin: 0 0 .5em; color: var(--heading); }
  h2 { font-size: clamp(1.8rem, 5.2vw, 2.7rem); font-weight: 800; letter-spacing: -.015em; }
  p { margin: 0 0 1rem; }
  img { max-width: 100%; height: auto; display: block; }
  a { color: var(--blue-d); text-decoration: none; }
  .wrap { width: 100%; max-width: var(--wrap); margin: 0 auto; padding: 0 20px; }

  /* Botones */
  .btn { display: inline-block; padding: 13px 26px; border-radius: 999px; font-weight: 700; font-family: 'Montserrat',sans-serif; font-size: .95rem; text-align: center; transition: transform .15s, background .15s; cursor: pointer; border: 0; }
  .btn-primary { background: var(--blue); color: #fff; }
  .btn-primary:hover { background: var(--blue-d); transform: translateY(-2px); }
  .btn-light { background: #fff; color: var(--blue-d); }
  .btn-outline { background: transparent; color: #fff; border: 2px solid #fff; }

  /* Barra superior */
  .topbar { background: var(--blue-dd); color: #dff0ff; font-size: .82rem; }
  .topbar-in { display: flex; align-items: center; gap: 16px; min-height: 38px; flex-wrap: wrap; }
  .topbar a { color: #eaf5ff; }
  .topbar-phone { font-weight: 700; }
  .topbar-addr { color: #b9dcf5; flex: 1; }
  .topbar-social { display: flex; gap: 12px; }
  .topbar-social a { display: inline-flex; align-items: center; opacity: .9; transition: opacity .15s, transform .15s; }
  .topbar-social a:hover { opacity: 1; transform: translateY(-1px); }
  @media (max-width: 640px) { .topbar-addr { display: none; } .topbar-in { justify-content: space-between; } }

  /* Cabecera */
  .header { position: sticky; top: 0; z-index: 50; background: rgba(255,255,255,.96); backdrop-filter: blur(6px); border-bottom: 1px solid var(--line); }
  .header-in { display: flex; align-items: center; justify-content: space-between; min-height: 66px; }
  .logo img { width: 150px; height: auto; }
  .nav { display: flex; align-items: center; gap: 22px; }
  .nav > a { color: var(--ink); font-weight: 600; font-size: .95rem; font-family: 'Montserrat',sans-serif; }
  .nav > a:hover, .nav > a.active { color: var(--blue-d); }
  .nav-cta { background: var(--blue); color: #fff !important; padding: 9px 18px; border-radius: 999px; }
  .nav-cta:hover { background: var(--blue-d); }
  .lang a { display: inline-block; border: 1px solid var(--line); border-radius: 6px; padding: 4px 9px; font-weight: 700; font-size: .82rem; color: var(--muted); }
  .navtoggle, .burger { display: none; }

  /* Nav móvil (hamburguesa CSS pura) */
  @media (max-width: 900px) {
    .burger { display: flex; flex-direction: column; justify-content: center; gap: 5px; width: 44px; height: 44px; cursor: pointer; }
    .burger span { display: block; height: 3px; width: 26px; background: var(--blue-dd); border-radius: 3px; transition: .25s; }
    /* Panel lateral azul de marca. Altura explícita (100dvh) para que no lo atrape el backdrop-filter de la cabecera. */
    .nav {
      position: fixed; top: 0; right: 0; bottom: auto;
      height: 100vh; height: 100dvh;
      width: min(80vw, 330px);
      flex-direction: column; align-items: stretch; gap: 2px;
      background: linear-gradient(165deg, var(--blue-d) 0%, var(--blue-dd) 100%);
      padding: 88px 26px 28px; overflow-y: auto;
      box-shadow: -12px 0 44px rgba(8, 40, 70, .45);
      transform: translateX(100%); transition: transform .3s cubic-bezier(.22,.61,.36,1);
    }
    .nav > a { color: #fff; padding: 15px 10px; border-bottom: 1px solid rgba(255,255,255,.16); font-size: 1.08rem; border-radius: 8px; }
    .nav > a:hover, .nav > a.active { color: #fff; background: rgba(255,255,255,.14); }
    .nav-cta { background: #fff; color: var(--blue-dd) !important; text-align: center; margin-top: 16px; border-bottom: 0; }
    .nav-cta:hover { background: #eaf4ff; }
    .lang { margin-top: 16px; }
    .lang a { color: #fff; border-color: rgba(255,255,255,.45); background: rgba(255,255,255,.08); }
    .navtoggle:checked ~ .nav { transform: translateX(0); }
    .navtoggle:checked ~ .burger span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
    .navtoggle:checked ~ .burger span:nth-child(2) { opacity: 0; }
    .navtoggle:checked ~ .burger span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
  }

  /* Secciones genéricas */
  section { padding: clamp(44px, 8vw, 80px) 0; }
  .section-soft { background: var(--bg-soft); }
  .section-head { text-align: center; max-width: 640px; margin: 0 auto clamp(28px,5vw,44px); }
  .section-head p { color: var(--muted); margin: 0; }

  /* WhatsApp flotante */
  .wa-fab { position: fixed; right: 18px; bottom: 18px; z-index: 60; width: 56px; height: 56px; border-radius: 50%; background: var(--wa); display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 20px rgba(37,211,102,.45); isolation: isolate; transition: transform .15s; }
  .wa-fab:hover { transform: scale(1.06); }
  .wa-fab::before { content: ''; position: absolute; inset: 0; border-radius: 50%; background: var(--wa); z-index: -1; }

  /* ---------- Embellecido: títulos con acento + microinteracciones ---------- */
  .section-head h2 { position: relative; display: inline-block; letter-spacing: -.01em; }
  .section-head h2::after { content: ''; display: block; width: 54px; height: 4px; border-radius: 4px; margin: 16px auto 0; background: linear-gradient(90deg, var(--blue), var(--blue-dd)); }
  /* subrayado animado en la navegación (escritorio) */
  @media (min-width: 901px) {
    .nav > a:not(.nav-cta) { position: relative; }
    .nav > a:not(.nav-cta)::after { content: ''; position: absolute; left: 0; right: 100%; bottom: -6px; height: 2px; border-radius: 2px; background: var(--blue); transition: right .25s ease; }
    .nav > a:not(.nav-cta):hover::after, .nav > a.active::after { right: 0; }
  }

  /* ---------- Animaciones (respetan prefers-reduced-motion; degradan sin ocultar contenido) ---------- */
  @media (prefers-reduced-motion: no-preference) {
    /* entrada del hero (escalonada, con desenfoque premium) — solo en la home */
    .hero-bg { animation: fade 1.1s ease both; }
    .hero-bg img { animation: kenburns 22s ease-out both; }
    .hero h1 { animation: rise .9s .1s both cubic-bezier(.22,.61,.36,1); }
    .hero-text { animation: rise .9s .24s both cubic-bezier(.22,.61,.36,1); }
    .hero-rating { animation: rise .9s .38s both cubic-bezier(.22,.61,.36,1); }
    .hero-cta { animation: rise .9s .52s both cubic-bezier(.22,.61,.36,1); }
    /* pulso del botón de WhatsApp */
    .wa-fab::before { animation: wa-pulse 2.6s ease-out infinite; }
  }
  /* Revelado al scroll: se oculta por SELECTOR bajo .js-reveal (marcado en <head> antes del primer pintado → sin parpadeo). El observer añade .in. */
  .js-reveal :is(.section-head, .tx-card, .team-card, .price-card, .clinic-item, .clinic-text p, .rev, .lesion, .partner-logo) {
    opacity: 0; transform: translateY(34px) scale(.982); filter: blur(8px);
    transition: opacity .7s ease, transform .9s cubic-bezier(.22,.61,.36,1), filter .8s ease;
  }
  .js-reveal :is(.section-head, .tx-card, .team-card, .price-card, .clinic-item, .clinic-text p, .rev, .lesion, .partner-logo).in {
    opacity: 1; transform: none; filter: none;
  }
  /* la barra de acento del título se dibuja al revelarse */
  .js-reveal .section-head h2::after { transform: scaleX(0); transform-origin: center; transition: transform .8s .25s cubic-bezier(.22,.61,.36,1); }
  .js-reveal .section-head.in h2::after { transform: scaleX(1); }
  @keyframes rise { from { opacity: 0; transform: translateY(26px); filter: blur(6px); } to { opacity: 1; transform: none; filter: none; } }
  @keyframes fade { from { opacity: 0; } to { opacity: 1; } }
  @keyframes kenburns { from { transform: scale(1.09); } to { transform: scale(1); } }
  @keyframes wa-pulse { 0% { transform: scale(1); opacity: .55; } 70% { transform: scale(1.7); opacity: 0; } 100% { opacity: 0; } }

  /* Pie */
  .footer { background: #14202e; color: #b7c6d4; padding: clamp(40px,6vw,60px) 0 0; margin-top: 20px; }
  .footer h3 { color: #fff; font-size: 1rem; margin-bottom: .8rem; }
  .footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 32px; }
  .footer-logo { margin-bottom: 14px; }
  .footer-tag { color: #8ea6bb; font-size: .9rem; }
  .footer-link { color: #b7c6d4; }
  .footer-link:hover { color: #fff; }
  .hours-list { list-style: none; padding: 0; margin: 0; font-size: .9rem; }
  .hours-list li { display: flex; justify-content: space-between; gap: 12px; padding: 4px 0; border-bottom: 1px dashed #2a3a4b; }
  .footer-social { display: flex; gap: 12px; margin-bottom: 4px; }
  .footer-social a { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,.08); color: #b7c6d4; transition: background .2s, color .2s, transform .2s; }
  .footer-social a:hover { background: var(--blue); color: #fff; transform: translateY(-2px); }
