---
import { routes, t, clinicText, clinicGallery, type Lang } from '../data/content';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const L = t[lang];
const r = routes[lang];
const paragraphs = clinicText[lang];
const gallery = clinicGallery[lang];
---
<section>
  <div class="wrap">
    <div class="section-head">
      <h2>{L.pages.clinic.title}</h2>
      <p>{L.pages.clinic.subtitle}</p>
    </div>
    <div class="clinic-text">
      {paragraphs.map(p => <p>{p}</p>)}
    </div>
  </div>
</section>

<section class="section-soft">
  <div class="wrap">
    <div class="section-head">
      <h2>{L.pages.clinic.galleryTitle}</h2>
    </div>
    <div class="clinic-grid">
      {gallery.map(g => (
        <figure class="clinic-item">
          <img src={g.img} alt={g.label} loading="lazy" width="380" height="260" />
          <figcaption>{g.label}</figcaption>
        </figure>
      ))}
    </div>
    <div class="clinic-cta"><a href={r.booking} class="btn btn-primary">{L.cta.book}</a></div>
  </div>
</section>

<style>
  .clinic-text { max-width: 780px; margin: 0 auto; }
  .clinic-text p { color: var(--muted); }
  .clinic-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
  .clinic-item { position: relative; margin: 0; border-radius: 16px; overflow: hidden; box-shadow: 0 6px 20px rgba(20,50,80,.06); background: #fff; }
  .clinic-item img { display: block; width: 100%; aspect-ratio: 3/2; height: auto; object-fit: cover; }
  .clinic-item figcaption { position: absolute; inset: auto 0 0 0; background: linear-gradient(transparent, rgba(12,40,68,.9)); color: #fff; font-size: .9rem; font-weight: 600; padding: 24px 14px 12px; font-family: 'Montserrat', sans-serif; }
  .clinic-cta { text-align: center; margin-top: 40px; }
  @media (max-width: 520px) { .clinic-grid { grid-template-columns: 1fr; } }
</style>
