---
import { routes, t, treatmentsList, type Lang } from '../data/content';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const L = t[lang];
const r = routes[lang];
const items = treatmentsList[lang];
---
<section>
  <div class="wrap">
    <div class="section-head">
      <h2>{L.pages.treatments.title}</h2>
      <p>{L.pages.treatments.subtitle}</p>
    </div>
    <div class="tx-grid">
      {items.map(c => (
        <article class="tx-card">
          <div class="tx-img"><img src={c.img} alt={c.name} loading="lazy" width="380" height="240" /></div>
          <div class="tx-body">
            <h3>{c.name}</h3>
            <p>{c.text}</p>
          </div>
        </article>
      ))}
    </div>
    <div class="tx-more"><a href={r.booking} class="btn btn-primary">{L.cta.book}</a></div>
  </div>
</section>

<style>
  .tx-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
  .tx-card { border: 1px solid var(--line); border-radius: 16px; overflow: hidden; background: #fff; box-shadow: 0 6px 20px rgba(20,50,80,.06); transition: transform .18s, box-shadow .18s; display: flex; flex-direction: column; }
  .tx-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(20,50,80,.12); }
  .tx-img { flex: 0 0 auto; }
  .tx-img img { display: block; width: 100%; aspect-ratio: 16/10; height: auto; object-fit: cover; }
  .tx-body { padding: 20px; }
  .tx-body h3 { color: var(--blue-dd); font-size: 1.15rem; }
  .tx-body p { color: var(--muted); font-size: .92rem; margin: 0; }
  .tx-more { text-align: center; margin-top: 40px; }
  @media (max-width: 520px) { .tx-grid { grid-template-columns: 1fr; } }
</style>
