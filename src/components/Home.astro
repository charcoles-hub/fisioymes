---
import { site } from '../data/site';
import { routes, t, testimonials, partners, type Lang } from '../data/content';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const L = t[lang];
const r = routes[lang];
const waLink = `https://wa.me/${site.whatsapp}`;
const lesionImgs = ['CERVICALGIAS','DORSALGIAS','LUMBALGIAS','RADICULOPATIAS','MIGRANAS','RIGIDESA-ARTICULAR','TENDINOPATIAS','HERNIA-DISCAL','SOBRECARGA-MUSCULAR','ROTURA-MUSCULAR','DRENAJE','PUNTOS-GATILLOS','SUELO-PELVICO','ATM','REHAB'];
const lesionExt = (n: string) => (n === 'MIGRANAS' ? 'jpg' : 'webp');
const base = import.meta.env.BASE_URL;
// Fotos reales de fisioymes.com. Excluida a propósito la del carrusel original con 4 membres de l'equip (petició del client).
const heroImages = ['hero2-electroterapia.webp', 'hero2-fisioterapia.webp', 'hero2-suelo-pelvico.webp', 'hero2-pilates.webp', 'hero2-estiramiento.webp', 'hero2-entrenamiento.webp'];
// Logo de Google (4 colores) para las reseñas.
const googleG = '<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="#4285F4" d="M22.5 12.2c0-.7-.06-1.4-.18-2.06H12v3.9h5.9a5.04 5.04 0 0 1-2.19 3.3v2.74h3.54c2.07-1.9 3.25-4.72 3.25-7.88z"/><path fill="#34A853" d="M12 23c2.94 0 5.42-.97 7.22-2.64l-3.54-2.74c-.98.66-2.24 1.05-3.68 1.05-2.83 0-5.23-1.91-6.09-4.48H2.26v2.82A10.98 10.98 0 0 0 12 23z"/><path fill="#FBBC05" d="M5.91 14.19a6.6 6.6 0 0 1 0-4.38V6.99H2.26a11 11 0 0 0 0 9.86l3.65-2.66z"/><path fill="#EA4335" d="M12 5.13c1.6 0 3.03.55 4.16 1.63l3.12-3.12A10.98 10.98 0 0 0 12 1 10.98 10.98 0 0 0 2.26 6.99l3.65 2.82C6.77 7.04 9.17 5.13 12 5.13z"/></svg>';
const initial = (name: string) => name.trim().charAt(0).toUpperCase();
---
<!-- HERO -->
<section class="hero">
  <div class="hero-bg" id="hero-track">
    {heroImages.map((img, i) => (
      <img src={base + 'assets/' + img} alt="Fisioymés" class="hero-slide" fetchpriority={i === 0 ? 'high' : 'auto'} loading="eager" />
    ))}
  </div>
  <button type="button" class="hero-arrow hero-prev" id="hero-prev" aria-label="Foto anterior"></button>
  <button type="button" class="hero-arrow hero-next" id="hero-next" aria-label="Foto siguiente"></button>
  <div class="hero-dots" id="hero-dots">
    {heroImages.map((_, i) => <button type="button" class="hero-dot" aria-label={`Foto ${i + 1}`}></button>)}
  </div>
  <script>
    const slides = Array.from(document.querySelectorAll('#hero-track .hero-slide'));
    const dots = Array.from(document.querySelectorAll('#hero-dots .hero-dot'));
    if (slides.length && dots.length) {
      let current = 0;
      let auto: ReturnType<typeof setInterval> | undefined;
      const goTo = (i: number) => {
        current = (i + slides.length) % slides.length;
        slides.forEach((s, idx) => {
          s.classList.remove('active');
          if (idx === current) void s.offsetWidth; // reinicia la animación CSS
        });
        slides[current].classList.add('active');
        dots.forEach((d, idx) => d.classList.toggle('active', idx === current));
      };
      const noAuto = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const stopAuto = () => clearInterval(auto);
      const startAuto = () => { if (!noAuto) auto = setInterval(() => goTo(current + 1), 5000); };
      // Tras interacción reinicia el temporizador (no lo detiene): sigue en automático
      const restartAuto = () => { stopAuto(); startAuto(); };
      dots.forEach((d, i) => d.addEventListener('click', () => { goTo(i); restartAuto(); }));
      const step = (dir: number) => { goTo(current + dir); restartAuto(); };
      document.getElementById('hero-prev')?.addEventListener('click', () => step(-1));
      document.getElementById('hero-next')?.addEventListener('click', () => step(1));
      // Swipe (dedo) + arrastre (ratón): umbral horizontal para pasar de foto
      const track = document.getElementById('hero-track');
      if (track) {
        let startX = 0, dragging = false;
        const down = (x: number) => { dragging = true; startX = x; };
        const up = (x: number) => {
          if (!dragging) return;
          dragging = false;
          const dx = x - startX;
          if (Math.abs(dx) > 40) step(dx < 0 ? 1 : -1);
        };
        track.addEventListener('touchstart', (e) => down(e.touches[0].clientX), { passive: true });
        track.addEventListener('touchend', (e) => up(e.changedTouches[0].clientX));
        track.addEventListener('mousedown', (e) => { e.preventDefault(); down(e.clientX); });
        window.addEventListener('mouseup', (e) => up(e.clientX));
      }
      startAuto();
      goTo(0);
    }
  </script>
  <div class="wrap hero-in">
    <h1>{L.hero.title}</h1>
    <p class="hero-text">{L.hero.text}</p>
    <div class="hero-rating">
      <span class="stars">★★★★★</span>
      <strong>{site.googleRating}</strong> · {L.hero.ratingText.replace('{n}', String(site.googleReviews))}
    </div>
    <div class="hero-cta">
      <a href={r.booking} class="btn btn-primary">{L.cta.book}</a>
      <a href="#contacte" class="btn btn-outline">{L.cta.contact}</a>
    </div>
  </div>
</section>

<!-- LESIONES (grid compacto) -->
<section class="section-soft">
  <div class="wrap">
    <div class="section-head">
      <h2>{L.lesions.title}</h2>
      <p>{L.lesions.subtitle}</p>
    </div>
    <input type="checkbox" id="more-lesions" class="more-toggle" hidden />
    <div class="lesion-grid">
      {L.lesions.items.map((item, i) => (
        <details class="lesion">
          <summary>
            <img src={`${base}assets/lesion-${lesionImgs[i]}.${lesionExt(lesionImgs[i])}`} alt={item.name} loading="lazy" width="140" height="98" />
            <span class="lesion-name">{item.name}</span>
            <span class="lesion-plus" aria-hidden="true"></span>
          </summary>
          <p class="lesion-desc">{item.desc}</p>
        </details>
      ))}
    </div>
    <div class="more-wrap"><label for="more-lesions" class="btn btn-primary more-btn">{L.lesions.more}</label></div>
  </div>
</section>

<!-- TRATAMIENTOS -->
<section>
  <div class="wrap">
    <div class="section-head">
      <h2>{L.treatments.title}</h2>
      <p>{L.treatments.subtitle}</p>
    </div>
    <div class="tx-grid">
      {L.treatments.cards.map(c => (
        <article class="tx-card">
          <div class="tx-img"><img src={c.img} alt={c.name} loading="lazy" width="380" height="240" />{'badge' in c && c.badge && <span class="tx-badge">{c.badge}</span>}</div>
          <div class="tx-body">
            <h3>{c.name}</h3>
            <p>{c.text}</p>
          </div>
        </article>
      ))}
    </div>
    <div class="tx-more"><a href={r.treatments} class="btn btn-primary">{L.cta.seeTreatments}</a></div>
  </div>
</section>

<!-- BANDA RESERVA -->
<section class="band">
  <div class="wrap band-in">
    <div>
      <h2>{L.cta.book}</h2>
      <p>{lang === 'ca' ? 'Reserva la teva cita online en menys d’un minut, quan et vagi bé.' : 'Reserva tu cita online en menos de un minuto, cuando mejor te vaya.'}</p>
    </div>
    <a href={r.booking} class="btn btn-light">{L.cta.book}</a>
  </div>
</section>

<!-- TESTIMONIOS -->
<section class="section-soft">
  <div class="wrap">
    <div class="section-head">
      <h2>{L.testimonials.title}</h2>
      <p>{L.testimonials.subtitle}</p>
    </div>
    <div class="rev-badge">
      <Fragment set:html={googleG} />
      <strong>{site.googleRating}</strong>
      <span class="stars">★★★★★</span>
      <span class="rev-badge-txt">· {site.googleReviews} {lang === 'ca' ? 'ressenyes a Google' : 'reseñas en Google'}</span>
    </div>
    <div class="rev-grid">
      {testimonials.map(rv => (
        <blockquote class="rev">
          <div class="rev-head">
            <span class="rev-av">{initial(rv.name)}</span>
            <div class="rev-meta">
              <cite>{rv.name}</cite>
              <span class="stars">★★★★★</span>
            </div>
            <span class="rev-g"><Fragment set:html={googleG} /></span>
          </div>
          <p>{rv.text}</p>
        </blockquote>
      ))}
    </div>
    <p class="rev-swipe" aria-hidden="true">{L.testimonials.swipe}</p>
  </div>
</section>

<!-- COLABORADORES -->
<section class="partners">
  <div class="wrap">
    <p class="partners-title">{L.partners.title}</p>
    <div class="partners-row">
      {partners.map(p => <img src={p.img} alt={p.name} loading="lazy" class="partner-logo" />)}
    </div>
  </div>
</section>

<!-- CONTACTO -->
<section id="contacte">
  <div class="wrap contact-grid">
    <div>
      <h2>{L.contact.title}</h2>
      <p class="contact-text">{L.contact.text}</p>
      <ul class="contact-list">
        <li><a href={site.phoneHref}>{site.phone}</a></li>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li><a href={site.mapsUrl} target="_blank" rel="noopener">{site.address} · {site.city}</a></li>
      </ul>
      <a href={waLink} class="btn wa-btn" target="_blank" rel="noopener">{L.cta.whatsapp}</a>
    </div>
    <!-- FormSubmit: envío real sin backend ni cuenta. El cliente debe confirmar una vez el primer email. -->
    <form class="contact-form" action={`https://formsubmit.co/${site.email}`} method="post">
      <input type="hidden" name="_subject" value="Nou missatge des de la web · Fisioymés" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />
      <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
      <label>{L.contact.name}<input type="text" name="Nom" required /></label>
      <label>{L.contact.email}<input type="email" name="Email" required /></label>
      <label>{L.contact.message}<textarea name="Missatge" rows="4"></textarea></label>
      <button type="submit" class="btn btn-primary">{L.contact.send}</button>
      <p class="contact-or">{L.contact.or} · {L.contact.prefer} <a href={r.booking}>{L.cta.book}</a></p>
    </form>
  </div>
</section>

<style>
  .stars { color: #f5a623; letter-spacing: 1px; }

  /* HERO */
  .hero { position: relative; color: #fff; padding: clamp(70px,14vw,150px) 0; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .hero-slide { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; }
  .hero-slide.active { opacity: 1; animation: hero-slide-in .7s ease-in-out; }
  @keyframes hero-slide-in { 0% { opacity: 0; transform: translateX(-4%); } 100% { opacity: 1; transform: translateX(0); } }
  .hero-arrow { position: absolute; z-index: 3; top: 50%; transform: translateY(-50%); width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; padding: 0; border: 0; border-radius: 50%; background: rgba(15,50,85,.4); cursor: pointer; transition: background .2s; -webkit-tap-highlight-color: transparent; }
  .hero-arrow:hover { background: rgba(15,50,85,.7); }
  .hero-arrow::before { content: ''; width: 10px; height: 10px; border: solid #fff; border-width: 0 2.5px 2.5px 0; }
  .hero-prev::before { transform: rotate(135deg); margin-left: 4px; }
  .hero-next::before { transform: rotate(-45deg); margin-right: 4px; }
  .hero-prev { left: 14px; }
  .hero-next { right: 14px; }
  /* Móvil: flechas abajo, junto a los puntitos, para no tapar el texto */
  @media (max-width: 640px) {
    .hero-arrow { top: auto; bottom: 6px; transform: none; width: 34px; height: 34px; }
    .hero-arrow::before { width: 8px; height: 8px; }
    .hero-prev { left: 20px; }
    .hero-next { right: 20px; }
  }
  .hero-bg { touch-action: pan-y; cursor: grab; }
  .hero-bg:active { cursor: grabbing; }
  .hero-dots { position: absolute; z-index: 3; bottom: 18px; left: 50%; transform: translateX(-50%); display: flex; gap: 9px; }
  .hero-dot { width: 10px; height: 10px; padding: 0; border: 0; border-radius: 50%; background: rgba(255,255,255,.5); cursor: pointer; transition: background .2s, transform .2s; }
  .hero-dot:hover { background: rgba(255,255,255,.8); }
  .hero-dot.active { background: #fff; transform: scale(1.3); }
  @media (prefers-reduced-motion: reduce) { .hero-slide.active { animation: none; } }
  .hero-bg::after { content: ''; position: absolute; inset: 0; z-index: 1; background: linear-gradient(105deg, rgba(15,50,85,.85) 0%, rgba(15,50,85,.55) 55%, rgba(15,50,85,.25) 100%); }
  .hero-in { position: relative; z-index: 2; max-width: 620px; }
  .hero h1 { color: #fff; font-size: clamp(2rem, 7vw, 3.2rem); font-weight: 800; }
  .hero-text { font-size: clamp(1rem, 2.4vw, 1.15rem); color: #eaf4fb; }
  .hero-rating { display: flex; align-items: center; gap: 8px; font-size: .95rem; margin-bottom: 22px; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

  /* LESIONES (desplegables) */
  .lesion-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 14px; align-items: start; }
  .lesion { border-radius: 12px; overflow: hidden; box-shadow: 0 4px 14px rgba(20,50,80,.09); background: #fff; }
  .lesion summary { position: relative; display: block; cursor: pointer; list-style: none; aspect-ratio: 3/2; }
  .lesion summary::-webkit-details-marker { display: none; }
  .lesion summary img { width: 100%; height: 100%; object-fit: cover; }
  .lesion-name { position: absolute; inset: auto 0 0 0; background: linear-gradient(transparent, rgba(12,40,68,.92)); color: #fff; font-size: .82rem; font-weight: 600; padding: 22px 34px 9px 10px; font-family: 'Montserrat',sans-serif; line-height: 1.25; }
  .lesion-plus { position: absolute; right: 8px; bottom: 8px; width: 22px; height: 22px; border-radius: 50%; background: var(--blue); display: flex; align-items: center; justify-content: center; transition: transform .2s, background .2s; }
  .lesion-plus::before, .lesion-plus::after { content: ''; position: absolute; background: #fff; border-radius: 2px; }
  .lesion-plus::before { width: 11px; height: 2px; }
  .lesion-plus::after { width: 2px; height: 11px; transition: opacity .2s; }
  .lesion[open] .lesion-plus { background: var(--blue-dd); }
  .lesion[open] .lesion-plus::after { opacity: 0; }
  .lesion-desc { margin: 0; padding: 12px 14px 14px; font-size: .84rem; color: var(--muted); line-height: 1.5; border-top: 2px solid var(--blue); }
  @media (max-width: 520px) { .lesion-grid { grid-template-columns: 1fr 1fr; gap: 10px; } .lesion-name { font-size: .76rem; padding-right: 30px; } .lesion-desc { font-size: .8rem; } }
  /* "Ver más" de lesiones: en móvil muestra 4 y revela el resto al pulsar; en escritorio se ven todas */
  .more-wrap { text-align: center; margin-top: 22px; }
  @media (min-width: 641px) { .more-wrap { display: none; } }
  @media (max-width: 640px) {
    .more-toggle:not(:checked) ~ .lesion-grid > .lesion:nth-child(n+5) { display: none; }
    .more-toggle:checked ~ .more-wrap { display: none; }
  }

  /* TRATAMIENTOS */
  .tx-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .tx-card { border: 1px solid var(--line); border-radius: 16px; overflow: hidden; background: #fff; box-shadow: 0 6px 20px rgba(20,50,80,.06); transition: transform .18s, box-shadow .18s; }
  .tx-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(20,50,80,.12); }
  .tx-img { position: relative; }
  .tx-img img { display: block; width: 100%; aspect-ratio: 16/10; height: auto; object-fit: cover; }
  .tx-badge { position: absolute; top: 12px; left: 12px; background: var(--wa); color: #fff; font-size: .78rem; font-weight: 700; padding: 5px 12px; border-radius: 999px; font-family: 'Montserrat',sans-serif; }
  .tx-body { padding: 20px; }
  .tx-body h3 { color: var(--blue-dd); font-size: 1.15rem; }
  .tx-body p { color: var(--muted); font-size: .92rem; margin: 0; }
  .tx-more { text-align: center; margin-top: 34px; }
  @media (max-width: 820px) { .tx-grid { grid-template-columns: 1fr; max-width: 440px; margin: 0 auto; } }

  /* BANDA */
  .band { background: linear-gradient(105deg, var(--blue) 0%, var(--blue-dd) 100%); color: #fff; }
  .band-in { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .band h2 { color: #fff; margin-bottom: 4px; }
  .band p { color: #e5f2fc; margin: 0; }

  /* TESTIMONIOS */
  .rev-badge { display: flex; width: fit-content; align-items: center; gap: 8px; margin: 0 auto clamp(28px,4vw,40px); padding: 9px 18px; background: #fff; border: 1px solid var(--line); border-radius: 999px; box-shadow: 0 4px 14px rgba(20,50,80,.06); font-size: .95rem; }
  .rev-badge strong { font-family: 'Montserrat',sans-serif; color: var(--ink); }
  .rev-badge .rev-badge-txt { color: var(--muted); }
  .rev-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .rev { margin: 0; background: #fff; border: 1px solid var(--line); border-radius: 16px; padding: 24px; box-shadow: 0 6px 20px rgba(20,50,80,.06); display: flex; flex-direction: column; gap: 14px; transition: transform .18s, box-shadow .18s; }
  .rev:hover { transform: translateY(-3px); box-shadow: 0 14px 30px rgba(20,50,80,.11); }
  .rev-head { display: flex; align-items: center; gap: 12px; }
  .rev-av { flex: 0 0 auto; width: 46px; height: 46px; border-radius: 50%; background: linear-gradient(135deg, var(--blue), var(--blue-dd)); color: #fff; display: flex; align-items: center; justify-content: center; font-family: 'Montserrat',sans-serif; font-weight: 700; font-size: 1.15rem; }
  .rev-meta { display: flex; flex-direction: column; gap: 1px; flex: 1; min-width: 0; }
  .rev-meta cite { font-style: normal; font-weight: 700; font-family: 'Montserrat',sans-serif; color: var(--ink); font-size: .95rem; }
  .rev-head .stars { font-size: .82rem; }
  .rev-g { flex: 0 0 auto; display: inline-flex; opacity: .95; }
  .rev p { font-size: .94rem; color: var(--muted); margin: 0; line-height: 1.6; }
  .rev-swipe { display: none; text-align: center; color: var(--muted); font-size: .85rem; margin: 14px 0 0; }
  /* Móvil: carrusel deslizable (scroll-snap nativo) para acortar el scroll vertical */
  @media (max-width: 820px) {
    .rev-grid {
      grid-template-columns: none; display: flex; gap: 14px;
      overflow-x: auto; scroll-snap-type: x mandatory;
      margin-inline: -20px; padding: 6px 20px 14px;
      scrollbar-width: none; -webkit-overflow-scrolling: touch;
    }
    .rev-grid::-webkit-scrollbar { display: none; }
    .rev { flex: 0 0 84%; scroll-snap-align: center; }
    .rev-swipe { display: block; }
  }

  /* COLABORADORES */
  .partners { padding: clamp(34px,5vw,52px) 0; }
  .partners-title { text-align: center; text-transform: uppercase; letter-spacing: 2px; font-size: .8rem; color: var(--muted); font-weight: 700; margin-bottom: 22px; }
  .partners-row { display: flex; align-items: center; justify-content: center; gap: clamp(24px,5vw,56px); flex-wrap: wrap; }
  .partner-logo { max-height: 52px; width: auto; opacity: .7; filter: grayscale(1); transition: .2s; }
  .partner-logo:hover { opacity: 1; filter: none; }

  /* CONTACTO */
  .contact-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 40px; align-items: start; }
  .contact-text { color: var(--muted); }
  .contact-list { list-style: none; padding: 0; margin: 0 0 20px; }
  .contact-list li { padding: 10px 0; border-bottom: 1px solid var(--line); }
  .wa-btn { background: var(--wa); color: #fff; }
  .wa-btn:hover { background: #1eb958; }
  .contact-form { background: var(--bg-soft); border: 1px solid var(--line); border-radius: 16px; padding: 26px; display: flex; flex-direction: column; gap: 14px; }
  .contact-form label { display: flex; flex-direction: column; gap: 6px; font-weight: 600; font-size: .88rem; color: var(--ink); }
  .contact-form input, .contact-form textarea { padding: 12px 14px; border: 1px solid var(--line); border-radius: 10px; font: inherit; font-size: .95rem; }
  .contact-form input:focus, .contact-form textarea:focus { outline: 2px solid var(--blue); border-color: var(--blue); }
  .contact-or { font-size: .85rem; color: var(--muted); margin: 4px 0 0; }
  @media (max-width: 820px) { .contact-grid { grid-template-columns: 1fr; gap: 28px; } }
</style>
